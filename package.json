{
  "name": "syspaq",
  "private": true,
  "packageManager": "pnpm@10.12.0",
  "scripts": {
    "dev:api": "pnpm --filter @syspaq/api dev",
    "dev:dashboard": "pnpm --filter @syspaq/dashboard dev",
    "dev:landing": "pnpm --filter @syspaq/landing dev",
    "build": "pnpm -r build",
    "lint": "pnpm --filter @syspaq/api lint",
    "deploy:api": "./scripts/deploy-api.sh",
    "deploy:api:migrate": "./scripts/deploy-api.sh --migrate",
    "deploy:api:logs": "./scripts/deploy-api.sh --logs",
    "deploy:api:status": "./scripts/deploy-api.sh --status",
    "seed": "pnpm --filter @syspaq/api prisma:seed",
    "seed:demo": "pnpm --filter @syspaq/api prisma:seed:demo"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma",
      "@prisma/engines",
      "@nestjs/core"
    ]
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
