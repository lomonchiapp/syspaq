# Copia este archivo en el VPS como `.env.release` (mismo directorio que docker-compose.yml).
# NUNCA subas `.env.release` a git — contiene secretos.
#
# DATABASE_URL: host `postgres` es el nombre del servicio en docker-compose.yml
NODE_ENV=production
PORT=3001

# Misma contraseña en DATABASE_URL y en POSTGRES_PASSWORD (usada por el servicio postgres)
POSTGRES_PASSWORD=cambia_esto_por_una_contraseña_larga

DATABASE_URL=postgresql://blumbox:cambia_esto_por_una_contraseña_larga@postgres:5432/blumbox_api?schema=public

JWT_SECRET=cambia_esto_minimo_32_caracteres_aleatorios
API_KEY_PEPPER=otro_secreto_largo_para_pepper_de_api_keys

# Dominios permitidos para CORS (separados por coma)
CORS_ORIGINS=https://syspaq.com,https://app.syspaq.com
